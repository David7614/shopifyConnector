generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model accesstokens {
  id            Int     @id @default(autoincrement())
  id_user       Int?
  access_token  String? @db.Text
  refresh_token String? @db.Text
  expiry        Int?
  scope         String? @db.VarChar(255)
  state         String? @db.Text
  user          user?   @relation(fields: [id_user], references: [id], onDelete: Cascade, map: "accesstokens_ibfk_1")

  @@index([id_user], map: "idx-user_config-id_user")
}

model customers {
  id                     Int       @id @default(autoincrement())
  customer_id            String?   @db.VarChar(85)
  email                  String    @db.VarChar(255)
  login                  String?   @db.VarChar(255)
  registration           DateTime  @db.DateTime(0)
  first_name             String    @default("") @db.VarChar(255)
  lastname               String    @default("") @db.VarChar(255)
  zip_code               String    @default("") @db.VarChar(55)
  phone                  String?   @default("") @db.VarChar(55)
  newsletter_frequency   String?   @db.VarChar(55)
  sms_frequency          String?   @db.VarChar(55)
  nlf_time               DateTime? @db.DateTime(0)
  data_permission        String?   @db.VarChar(55)
  tags                   String?   @db.Text
  server_response        String?   @db.Text
  error                  String?   @db.Text
  data_hash              String?   @db.VarChar(255)
  last_modification_date DateTime? @db.DateTime(0)
  user_id                Int
  page                   Int
  parameters             String    @db.Text
  is_wholesaler          Int       @default(0)
  is_disabled            Int       @default(0)
  country                String    @default("") @db.VarChar(25)
  updated                DateTime  @default(now()) @db.Timestamp(0)
  verify_email           Boolean?
  shop_id                Boolean?
  crm_verified           Boolean   @default(false)
  user                   user      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "customers_ibfk_1")

  @@index([customer_id], map: "customer_id")
  @@index([email], map: "email")
  @@index([user_id], map: "user_id")
}

model disabled_feeds {
  id               Int    @id @default(autoincrement())
  user_id          Int
  integration_type String @db.VarChar(255)
  user             user   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "disabled_feeds_ibfk_1")

  @@index([user_id], map: "user_id")
}

model idosel_subscriptions {
  id                  Int       @id @default(autoincrement())
  customer_id         Int?
  customer_login      String?   @db.VarChar(255)
  customer_email      String?   @db.VarChar(255)
  customer_phone      String?   @db.VarChar(20)
  newsletter_approval Int       @default(0)
  sms_approval        Int       @default(0)
  date_modification   DateTime? @db.DateTime(0)
  shop_id             Int
  user_id             Int
  sync_flag           Int       @default(0)
  user                user      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "idosel_subscriptions_ibfk_1")

  @@index([customer_email], map: "customer_email")
  @@index([customer_id], map: "customer_id")
  @@index([user_id], map: "user_id")
}

model integration_data {
  id          Int    @id @default(autoincrement())
  customer_id Int
  task        String @db.VarChar(255)
  value       String @db.VarChar(255)
  user        user   @relation(fields: [customer_id], references: [id], onDelete: Cascade, map: "integration_data_ibfk_3")

  @@index([customer_id], map: "customer_id")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model magazines {
  id            Int
  location_id   Int
  parent_id     Int
  location_name String @db.VarChar(255)
  location_path String @db.VarChar(255)
  location_code String @db.VarChar(255)
  stock_id      Int
  user_id       Int
  user          user   @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "magazines_ibfk_2")

  @@index([user_id], map: "user_id")
  @@ignore
}

model orders {
  id              Int         @id @default(autoincrement())
  order_id        String      @db.VarChar(255)
  customer_id     Int?
  created_on      DateTime    @db.DateTime(0)
  finished_on     DateTime?   @db.DateTime(0)
  status          String      @db.VarChar(255)
  email           String?     @db.VarChar(255)
  phone           String?     @db.VarChar(55)
  zip_code        String?     @db.VarChar(55)
  country_code    String?     @db.VarChar(55)
  user_id         Int
  page            Int
  order_positions String      @db.Text
  updated         DateTime    @default(now()) @db.Timestamp(0)
  user            user        @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "orders_ibfk_2")
  positions       positions[]

  @@unique([order_id, user_id], map: "order_id_user_id")
  @@index([customer_id], map: "customer_id")
  @@index([user_id], map: "user_id")
}

model ordersv2 {
  id              Int       @id @default(autoincrement())
  order_id        Int
  customer_id     Int?
  created_on      DateTime  @db.DateTime(0)
  finished_on     DateTime? @db.DateTime(0)
  status          String    @db.VarChar(255)
  email           String?   @db.VarChar(255)
  phone           String?   @db.VarChar(55)
  zip_code        String?   @db.VarChar(55)
  country_code    String?   @db.VarChar(55)
  user_id         Int
  page            Int
  order_positions String    @db.Text
  updated         DateTime  @default(now()) @db.Timestamp(0)
  user            user      @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "ordersv2_ibfk_1")

  @@unique([order_id, user_id], map: "order_id_user_id")
  @@index([customer_id], map: "customer_id")
  @@index([order_id], map: "order_id")
  @@index([user_id], map: "user_id")
}

model positions {
  id         Int    @id @default(autoincrement())
  product_id Int
  amount     Int
  price      String @db.VarChar(255)
  order_id   Int
  orders     orders @relation(fields: [order_id], references: [id], onDelete: Cascade, map: "positions_ibfk_2")

  @@index([order_id], map: "order_id")
}

model product {
  ID                    Int      @id @default(autoincrement())
  PRODUCT_ID            Int
  URL                   String   @db.VarChar(550)
  TITLE                 String   @db.VarChar(250)
  PRICE                 Float
  BRAND                 String   @db.VarChar(250)
  DESCRIPTION           String   @db.Text
  PRICE_BEFORE_DISCOUNT Float    @default(0)
  PRICE_WHOLESALE       Float    @default(0)
  PRICE_BUY             Float    @default(0)
  IMAGE                 String   @default("") @db.VarChar(250)
  PRODUCT_LINE          String   @db.VarChar(250)
  CATEGORYTEXT          String   @db.Text
  SHOW                  String   @db.VarChar(55)
  PARAMETERS            String   @db.LongText
  VARIANT               String   @db.LongText
  PRICES                String   @db.Text
  STOCK                 Int      @default(0)
  response              String   @db.LongText
  params_hash           String   @db.VarChar(50)
  user_id               Int
  translation           String   @db.VarChar(5)
  created               DateTime @default(now()) @db.Timestamp(0)
  fixed_url             Int      @default(0)
  deleted               Int      @default(0)
  parent_id             Int      @default(0)
  variants_names        String   @default("") @db.VarChar(250)
  variants_values       String   @db.Text
  from_api_page         Int?
  user                  user     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "product_ibfk_1")

  @@index([user_id], map: "user_id")
}

model shoper_access_tokens {
  id            Int           @id @default(autoincrement()) @db.UnsignedInt
  shop_id       Int?          @db.UnsignedInt
  expires_at    DateTime?     @db.Timestamp(0)
  created_at    DateTime?     @default(now()) @db.Timestamp(0)
  access_token  String?       @db.Char(50)
  refresh_token String?       @db.Char(50)
  shoper_shops  shoper_shops? @relation(fields: [shop_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_access_tokens_shops")

  @@index([shop_id], map: "shop_id")
}

model shoper_attributes {
  id                        Int                         @id @default(autoincrement())
  shoper_shops_id           Int                         @db.UnsignedInt
  attribute_id              Int
  name                      String                      @db.VarChar(250)
  description               String                      @db.Text
  shoper_shops              shoper_shops                @relation(fields: [shoper_shops_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "shoper_attributes_ibfk_1")
  shoper_attributes_options shoper_attributes_options[]

  @@index([shoper_shops_id], map: "shoper_shops_id")
}

model shoper_attributes_options {
  id                   Int               @id @default(autoincrement())
  shoper_attributes_id Int
  option_id            Int
  value                String            @db.VarChar(250)
  shoper_attributes    shoper_attributes @relation(fields: [shoper_attributes_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "shoper_attributes_options_ibfk_1")

  @@index([shoper_attributes_id], map: "shoper_attributes_id")
}

model shoper_billings {
  id           Int           @id @default(autoincrement()) @db.UnsignedInt
  shop_id      Int?          @db.UnsignedInt
  created_at   DateTime?     @default(now()) @db.Timestamp(0)
  shoper_shops shoper_shops? @relation(fields: [shop_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_billings_shops")

  @@index([shop_id], map: "shop_id")
}

model shoper_categories {
  id                         Int                          @id @default(autoincrement())
  shoper_shops_id            Int                          @db.UnsignedInt
  category_id                Int
  order                      Int
  root                       Int
  in_loyalty                 Int
  parent_id                  Int?
  shoper_shops               shoper_shops                 @relation(fields: [shoper_shops_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "shoper_categories_ibfk_1")
  shoper_categories_language shoper_categories_language[]

  @@index([shoper_shops_id], map: "shoper_shops_id")
}

model shoper_categories_language {
  id                   Int               @id @default(autoincrement())
  shoper_categories_id Int
  translation          String            @db.VarChar(5)
  name                 String            @db.VarChar(250)
  description          String            @db.Text
  description_bottom   String            @db.Text
  active               Int
  isdefault            Int
  seo_title            String            @db.VarChar(250)
  seo_description      String            @db.VarChar(250)
  seo_keywords         String            @db.VarChar(250)
  permalink            String            @db.VarChar(250)
  shoper_categories    shoper_categories @relation(fields: [shoper_categories_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "shoper_categories_language_ibfk_1")

  @@index([shoper_categories_id], map: "shoper_categories_id")
}

model shoper_currencies_list {
  id              Int          @id @default(autoincrement())
  shoper_shops_id Int          @db.UnsignedInt
  currency_id     Int
  name            String       @db.VarChar(50)
  rate            Float        @db.Float
  active          Int
  order           Int
  default         Int
  rate_sync       Float        @db.Float
  rate_date       DateTime     @db.DateTime(0)
  shoper_shops    shoper_shops @relation(fields: [shoper_shops_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "shoper_currencies_list_ibfk_1")

  @@index([shoper_shops_id], map: "shoper_shops_id")
}

model shoper_languages_list {
  id              Int          @id @default(autoincrement()) @db.UnsignedInt
  shoper_shops_id Int          @db.UnsignedInt
  locale          String       @db.VarChar(5)
  currency_id     Int
  active          Int
  order           Int
  shoper_shops    shoper_shops @relation(fields: [shoper_shops_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "shoper_languages_list_ibfk_1")

  @@index([shoper_shops_id], map: "shoper_shops_id")
}

model shoper_metafields {
  id              Int          @id @default(autoincrement())
  metafield_id    Int
  shoper_shops_id Int          @db.UnsignedInt
  object          String       @db.VarChar(10)
  key             String       @db.VarChar(25)
  namespace       String       @db.VarChar(15)
  description     String       @db.VarChar(250)
  type            Int
  shoper_shops    shoper_shops @relation(fields: [shoper_shops_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "shoper_metafields_ibfk_1")

  @@index([shoper_shops_id], map: "shoper_shops_id")
}

model shoper_producer {
  id              Int          @id @default(autoincrement())
  producer_id     Int
  shoper_shops_id Int          @db.UnsignedInt
  name            String       @db.VarChar(250)
  shoper_shops    shoper_shops @relation(fields: [shoper_shops_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "shoper_producer_ibfk_1")

  @@index([shoper_shops_id], map: "shoper_shops_id")
}

model shoper_shops {
  id                     Int                      @id @default(autoincrement()) @db.UnsignedInt
  created_at             DateTime?                @default(now()) @db.Timestamp(0)
  shop                   String?                  @db.VarChar(128)
  shop_url               String?                  @db.VarChar(512)
  version                Int?
  installed              Int?                     @default(0) @db.SmallInt
  shoper_access_tokens   shoper_access_tokens[]
  shoper_attributes      shoper_attributes[]
  shoper_billings        shoper_billings[]
  shoper_categories      shoper_categories[]
  shoper_currencies_list shoper_currencies_list[]
  shoper_languages_list  shoper_languages_list[]
  shoper_metafields      shoper_metafields[]
  shoper_producer        shoper_producer[]
  shoper_status          shoper_status[]
  shoper_subscribers     shoper_subscribers[]
  shoper_subscriptions   shoper_subscriptions[]
  shoper_user_address    shoper_user_address[]
  shoper_user_tag        shoper_user_tag[]

  @@index([shop], map: "shop")
}

model shoper_status {
  id              Int          @id @default(autoincrement())
  shoper_shops_id Int          @db.UnsignedInt
  status_id       Int
  active          Int
  default         Int
  type            Int
  order           Int
  translation     String       @db.VarChar(5)
  name            String       @db.VarChar(250)
  message         String       @db.Text
  shoper_shops    shoper_shops @relation(fields: [shoper_shops_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "shoper_status_ibfk_2")

  @@index([order], map: "order")
  @@index([shoper_shops_id], map: "shoper_shops_id")
}

model shoper_subscribers {
  id              Int          @id @default(autoincrement())
  subscriber_id   Int
  shoper_shops_id Int          @db.UnsignedInt
  email           String       @db.VarChar(250)
  active          Int
  used            Int?         @default(0)
  dateadd         DateTime     @db.DateTime(0)
  ipaddress       String?      @db.VarChar(50)
  lang_id         Int
  groups          String       @db.VarChar(250)
  shoper_shops    shoper_shops @relation(fields: [shoper_shops_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "shoper_subscribers_ibfk_1")

  @@index([shoper_shops_id], map: "shoper_shops_id")
}

model shoper_subscriptions {
  id           Int          @id @default(autoincrement()) @db.UnsignedInt
  shop_id      Int          @db.UnsignedInt
  expires_at   DateTime?    @db.Timestamp(0)
  shoper_shops shoper_shops @relation(fields: [shop_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_subscriptions_shops")

  @@index([shop_id], map: "shop_id")
}

model shoper_user_address {
  id                        Int          @id @default(autoincrement())
  shoper_shops_id           Int          @db.UnsignedInt
  address_book_id           Int          @db.UnsignedInt
  user_id                   Int
  address_name              String       @db.VarChar(250)
  company_name              String       @db.VarChar(250)
  pesel                     String       @db.VarChar(25)
  firstname                 String       @db.VarChar(250)
  lastname                  String       @db.VarChar(250)
  street_1                  String       @db.VarChar(250)
  street_2                  String       @db.VarChar(250)
  city                      String       @db.VarChar(250)
  zip_code                  String       @db.VarChar(15)
  state                     String       @db.VarChar(15)
  country                   String       @db.VarChar(15)
  default                   Int
  shipping_default          Int
  phone                     String       @db.VarChar(25)
  sortkey                   String       @db.VarChar(250)
  country_code              String       @db.VarChar(5)
  tax_identification_number String       @db.VarChar(50)
  shoper_shops              shoper_shops @relation(fields: [shoper_shops_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "shoper_user_address_ibfk_1")

  @@index([shoper_shops_id], map: "shoper_shops_id")
}

model shoper_user_tag {
  id              Int          @id @default(autoincrement())
  shoper_shops_id Int          @db.UnsignedInt
  tag_id          Int
  name            String       @db.VarChar(250)
  lang_id         Int
  shoper_shops    shoper_shops @relation(fields: [shoper_shops_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "shoper_user_tag_ibfk_1")

  @@index([shoper_shops_id], map: "shoper_shops_id")
}

model user {
  id                   Int                    @id @default(autoincrement())
  username             String                 @db.VarChar(255)
  fronturl             String                 @default("") @db.VarChar(255)
  email                String                 @db.VarChar(255)
  password             String                 @db.VarChar(255)
  register_date        DateTime               @db.DateTime(0)
  active               Int                    @default(1) @db.TinyInt
  registerToken        String                 @db.VarChar(255)
  client_id            String                 @db.VarChar(255)
  client_secret        String                 @db.VarChar(255)
  uuid                 String                 @db.VarChar(255)
  shop_type            String                 @db.VarChar(10)
  user_type            String?                @db.VarChar(10)
  accesstokens         accesstokens[]
  customers            customers[]
  disabled_feeds       disabled_feeds[]
  idosel_subscriptions idosel_subscriptions[]
  integration_data     integration_data[]
  magazines            magazines[]            @ignore
  orders               orders[]
  ordersv2             ordersv2[]
  product              product[]
  user_config          user_config[]
  user_data            user_data[]
  xml_feed_queue       xml_feed_queue[]
}

model user_config {
  id      Int     @id @default(autoincrement())
  id_user Int?
  key     String  @db.VarChar(255)
  value   String? @db.VarChar(255)
  user    user?   @relation(fields: [id_user], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk-user_config-id_user")

  @@index([id_user], map: "idx-user_config-id_user")
}

model user_data {
  id      Int    @id @default(autoincrement())
  user_id Int
  name    String @db.VarChar(50)
  value   String @db.VarChar(250)
  user    user   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "user_data_ibfk_1")

  @@index([user_id], map: "user_id")
}

model xml_feed_queue {
  id                     Int      @id @default(autoincrement())
  integrated             Int
  next_integration_date  DateTime @db.DateTime(0)
  executed_at            DateTime @default(now()) @db.DateTime(0)
  finished_at            DateTime @default(now()) @db.DateTime(0)
  integration_type       String   @db.VarChar(255)
  current_integrate_user Int
  page                   Int
  max_page               Int
  parameters             String   @db.Text
  user                   user     @relation(fields: [current_integrate_user], references: [id], onDelete: Cascade, map: "xml_feed_queue_ibfk_1")

  @@index([current_integrate_user], map: "current_integrate_user")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}
